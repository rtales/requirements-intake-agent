{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/req-agent/requirement.v1.json",
  "title": "Requirement Package (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "problem",
    "scope",
    "stakeholders",
    "requirements",
    "acceptance_criteria",
    "nfr",
    "open_questions",
    "risks"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "created_at",
        "version",
        "source",
        "classification",
        "llm_trace"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Deterministic ID (e.g., REQ-2026-000123 or UUID)"
        },
        "title": {
          "type": "string",
          "minLength": 5
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "pattern": "^v\\d+(\\.\\d+){0,2}$",
          "default": "v1"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "needs_info",
            "review",
            "approved",
            "rejected",
            "archived"
          ],
          "default": "draft"
        },
        "owner_area": {
          "type": "string",
          "description": "Owning business area/team"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "channel",
            "raw_hash",
            "redaction_applied"
          ],
          "properties": {
            "channel": {
              "type": "string",
              "enum": [
                "form",
                "email",
                "meeting_notes",
                "free_text",
                "import"
              ]
            },
            "raw_hash": {
              "type": "string",
              "description": "SHA256 of normalized raw input."
            },
            "redaction_applied": {
              "type": "boolean"
            },
            "attachments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "classification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sensitivity",
            "domain",
            "confidence"
          ],
          "properties": {
            "sensitivity": {
              "type": "string",
              "enum": [
                "public",
                "internal",
                "restricted",
                "confidential"
              ]
            },
            "domain": {
              "type": "string",
              "enum": [
                "infra",
                "servicedesk",
                "bi",
                "data",
                "app",
                "security",
                "other"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "llm_trace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider",
            "model",
            "tokens_in",
            "tokens_out",
            "cost_estimate",
            "run_id",
            "policy"
          ],
          "properties": {
            "provider": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "tokens_in": {
              "type": "integer",
              "minimum": 0
            },
            "tokens_out": {
              "type": "integer",
              "minimum": 0
            },
            "cost_estimate": {
              "type": "number",
              "minimum": 0,
              "description": "Estimated cost (configured currency)."
            },
            "run_id": {
              "type": "string",
              "description": "Correlation id for logs/tracing"
            },
            "policy": {
              "type": "string",
              "description": "Policy/profile used (e.g., 'pilot-readonly')"
            }
          }
        }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context",
        "pain_points",
        "goal",
        "success_definition"
      ],
      "properties": {
        "context": {
          "type": "string"
        },
        "pain_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "goal": {
          "type": "string"
        },
        "success_definition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_scope",
        "out_of_scope",
        "assumptions",
        "constraints"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stakeholders": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requester",
        "product_owner",
        "tech_lead",
        "approvers",
        "users"
      ],
      "properties": {
        "requester": {
          "$ref": "#/$defs/person"
        },
        "product_owner": {
          "$ref": "#/$defs/person"
        },
        "tech_lead": {
          "$ref": "#/$defs/person"
        },
        "approvers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/person"
          }
        },
        "users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "statement",
          "priority",
          "rationale",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R\\d{3,}$"
          },
          "type": {
            "type": "string",
            "enum": [
              "functional",
              "data",
              "integration",
              "reporting",
              "ux",
              "operational",
              "security"
            ]
          },
          "statement": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "could",
              "wont"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "$ref": "#/$defs/evidence"
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "criterion",
          "linked_requirements"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC\\d{3,}$"
          },
          "criterion": {
            "type": "string"
          },
          "linked_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^R\\d{3,}$"
            }
          }
        }
      }
    },
    "nfr": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "security",
        "privacy",
        "availability",
        "performance",
        "observability",
        "usability",
        "compliance"
      ],
      "properties": {
        "security": {
          "$ref": "#/$defs/nfr_block"
        },
        "privacy": {
          "$ref": "#/$defs/nfr_block"
        },
        "availability": {
          "$ref": "#/$defs/nfr_block"
        },
        "performance": {
          "$ref": "#/$defs/nfr_block"
        },
        "observability": {
          "$ref": "#/$defs/nfr_block"
        },
        "usability": {
          "$ref": "#/$defs/nfr_block"
        },
        "compliance": {
          "$ref": "#/$defs/nfr_block"
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "question",
          "why_it_matters",
          "target",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^Q\\d{3,}$"
          },
          "question": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "answered",
              "parked"
            ],
            "default": "open"
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "risk",
          "impact",
          "likelihood",
          "mitigation",
          "owner",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RK\\d{3,}$"
          },
          "risk": {
            "type": "string"
          },
          "impact": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "likelihood": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "mitigation": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "mitigated",
              "accepted"
            ],
            "default": "open"
          }
        }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision_log": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decision"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "area"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "area": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_excerpt",
        "source_ref"
      ],
      "properties": {
        "source_excerpt": {
          "type": "string",
          "description": "Short excerpt (<= 240 chars) from the raw input or approved KB."
        },
        "source_ref": {
          "type": "string",
          "description": "Pointer to where excerpt came from (e.g., 'FORM:field:objective')."
        }
      }
    },
    "nfr_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "notes",
        "checks"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "unknown",
            "ok",
            "needs_review",
            "blocked"
          ],
          "default": "unknown"
        },
        "notes": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "date",
        "decision",
        "rationale",
        "by"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "decision": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "by": {
          "type": "string"
        }
      }
    }
  }
}